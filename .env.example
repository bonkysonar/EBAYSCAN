# Mock-first mode needs no environment variables.

# Optional real eBay Browse API integration for local dev:
# EBAY_ENV=production
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE_ID=EBAY_US
# Required before an eBay acquisition listing can become verified purchase evidence.
# Without it, eBay results remain useful discovery leads but cannot become automatic BUYs.
# EBAY_DELIVERY_POSTAL_CODE=
# Optional short-lived application token override for retail acquisition scans:
# EBAY_BROWSE_ACCESS_TOKEN=

# Optional Discogs marketplace stats:
# DISCOGS_USER_TOKEN=

# Optional read-only seller price analyzer:
# Prefer a long-lived OAuth refresh token so the server can mint short-lived user
# access tokens automatically. Keep both values server-side only.
# EBAY_USER_REFRESH_TOKEN=
# EBAY_USER_ACCESS_TOKEN=

# Optional hosted retail arbitrage publishing:
# Vercel Blob token is set by the Vercel Blob store integration on the hosted app.
# BLOB_READ_WRITE_TOKEN=
# Shared secret required by POST /api/arbitrage/upload on the hosted app and local automation.
# ARBITRAGE_UPLOAD_TOKEN=
# Local automation target, for example:
# ARBITRAGE_UPLOAD_URL=https://ebayscan.vercel.app/api/arbitrage/upload

# Hosted deployments should set the same values in the hosting provider's
# server-side environment variable dashboard, never in committed files.

