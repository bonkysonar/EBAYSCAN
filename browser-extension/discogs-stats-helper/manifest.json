{
  "manifest_version": 3,
  "name": "Record Scanner Discogs Helper",
  "description": "Reads Discogs release sales stats for the Record Scanner workbench.",
  "minimum_chrome_version": "102",
  "version": "0.3.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.discogs.com/*", "https://discogs.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:*/*",
        "http://localhost:*/*",
        "https://ebayscan.vercel.app/*",
        "https://*.vercel.app/*"
      ],
      "js": ["appContent.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.discogs.com/*", "https://discogs.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

